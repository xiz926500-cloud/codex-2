# Copy to .env for local-only secrets and machine-specific settings.
# Never commit real credentials.

APP_ENV=development
LOG_LEVEL=info

# Backend
APP_NAME=codex-2 API
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+asyncpg://codex:codex@localhost:5432/codex
REDIS_URL=redis://localhost:6379/0

# Frontend
VITE_API_BASE_URL=

# Docker Compose data services
POSTGRES_USER=codex
POSTGRES_PASSWORD=codex
POSTGRES_DB=codex
