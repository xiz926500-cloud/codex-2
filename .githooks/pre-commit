#!/usr/bin/env sh
set -eu

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -File scripts/pre-commit.ps1
fi

if command -v powershell.exe >/dev/null 2>&1; then
  exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/pre-commit.ps1
fi

echo "PowerShell is required to run the repository pre-commit hook." >&2
exit 1
